{
  "version": 2,
  "framework": "vite",
  "rootDirectory": "client",
  "buildCommand": "bun run build",
  "installCommand": "bun install",
  "outputDirectory": "dist",
  "rewrites": [
    {
      "source": "/health",
      "destination": "https://server-git-main-nelgoezs-projects.vercel.app/health"
    },
    {
      "source": "/docs",
      "destination": "https://server-git-main-nelgoezs-projects.vercel.app/docs"
    },
    {
      "source": "/api-spec",
      "destination": "https://server-git-main-nelgoezs-projects.vercel.app/api-spec"
    },
    { "source": "/(.*)", "destination": "/index.html" }
  ]
}
