# ===========================================
# Diploma Tracking System - Environment Variables
# ===========================================
# Copy this file to .env and fill in your values
# DO NOT commit .env to version control

# ===========================================
# SUPABASE
# ===========================================
# Get these from your Supabase project settings
# https://supabase.com/dashboard/project/_/settings/api
SUPABASE_URL=https://your-project-id.supabase.co
SUPABASE_ANON_KEY=your-anon-key
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key

# ===========================================
# JWT AUTHENTICATION
# ===========================================
# Generate a secure secret (min 32 characters)
# openssl rand -base64 32
JWT_SECRET=your-secret-key-minimum-32-characters
JWT_EXPIRES_IN=24h
JWT_REFRESH_EXPIRES_IN=7d

# ===========================================
# MOODLE INTEGRATION (Placeholder)
# ===========================================
# Configure when Moodle integration is ready
MOODLE_API_URL=https://moodle.unc.edu.ar
MOODLE_API_TOKEN=placeholder-token

# ===========================================
# GUARANÍ INTEGRATION (Placeholder)
# ===========================================
# Configure when Guaraní integration is ready
GUARANI_API_URL=https://guarani.unc.edu.ar
GUARANI_API_TOKEN=placeholder-token

# ===========================================
# SERVER CONFIGURATION
# ===========================================
NODE_ENV=development
PORT=3000
CORS_ORIGIN=http://localhost:5173

# ===========================================
# CLIENT CONFIGURATION (.env for Vite)
# ===========================================
# Copy these to client/.env for frontend
VITE_API_URL=http://localhost:3000/api/v1
VITE_SUPABASE_URL=https://your-project-id.supabase.co
VITE_SUPABASE_ANON_KEY=your-anon-key