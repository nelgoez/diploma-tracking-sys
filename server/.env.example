# ===========================================
# Diploma Tracking System — Environment Variables
# ===========================================
# Copy to .env and fill in your values.
# Never commit .env to version control.

# ----------------------------------------------------------------------------
# Supabase (PostgreSQL + Auth)
# ----------------------------------------------------------------------------
SUPABASE_URL=https://your-project.supabase.co
SUPABASE_ANON_KEY=sb_publishable_...
SUPABASE_SERVICE_ROLE_KEY=sb_secret_...

# ----------------------------------------------------------------------------
# JWT Authentication
# ----------------------------------------------------------------------------
JWT_SECRET=your-secret-key-minimum-32-characters
JWT_EXPIRES_IN=24h
JWT_REFRESH_EXPIRES_IN=7d

# ----------------------------------------------------------------------------
# Moodle LMS Integration (Certificate Provider)
# ----------------------------------------------------------------------------
MOODLE_API_URL=https://campus.aulavirtual.unc.edu.ar
MOODLE_API_TOKEN=your-moodle-web-service-token

# ----------------------------------------------------------------------------
# SIU Guaraní Integration (Academic Provider)
# ----------------------------------------------------------------------------
GUARANI_API_URL=https://guarani.unc.edu.ar
GUARANI_API_TOKEN=your-guarani-api-token

# ----------------------------------------------------------------------------
# Mock / Demo Mode
# ----------------------------------------------------------------------------
# Set to 'true' to bypass real API calls. Both Moodle and Guaraní return
# realistic fixture data. Health checks report 'connected'. Sync endpoints
# still write to the database (UPSERTs), so you can demo the full flow.
#
#   MOCK_MODE=true   → demos, local dev, CI/CD (no real creds needed)
#   MOCK_MODE=false  → production (real APIs must be reachable)
#
MOCK_MODE=false

# ----------------------------------------------------------------------------
# Server
# ----------------------------------------------------------------------------
NODE_ENV=production
PORT=3000
CORS_ORIGIN=http://localhost:5173
CRON_SECRET=change-me-in-production
